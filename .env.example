# Airflow HTTP connection URI for CoinGecko demo access.
# Replace <YOUR_DEMO_API_KEY> with your personal key.
AIRFLOW_CONN_COINGECKO_API=http://:@api.coingecko.com?extra__http__x_cg_demo_api_key=<YOUR_DEMO_API_KEY>

# Optional legacy var. Keep only if you use custom scripts.
# COINGECKO_API_KEY=<YOUR_DEMO_API_KEY>
